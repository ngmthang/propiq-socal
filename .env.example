# PropIQ - Environment Variable

DATABASE_URL=postgresql://propiq:propiq@localhost/propiq
ENVIRONMENT=development
DEBUG=true

# Comma-separated list of accepted API keys
PROPIQ_API_KEYS=propiq-dev-key-change-me

ENABLE_ML_SCHEDULER=true
ENABLE_AI_ANALYSIS=true
ANTHROPIC_API_KEY=

AVM_MODEL_PATH=/app/models/avm/latest
LSTM_MODEL_PATH=/app/models/lstm/latest

AVM_RETRAIN_CRON=0 3 * * 0
LSTM_RETRAIN_CRON=0 4 1 * *

CORS_ORIGINS=*